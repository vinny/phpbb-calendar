{
	"name": "vinny/calendar",
	"type": "phpbb-extension",
	"description": "Calendar and event manager extension for phpBB",
	"homepage": "https://github.com/vinny/phpbb-calendar",
	"version": "1.0.0",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Vinny",
			"role": "Developer"
		}
	],
	"require": {
		"php": ">=7.2.0"
	},
	"extra": {
		"display-name": "EventBoard Calendar",
		"soft-require": {
			"phpbb/phpbb": ">=3.3.0,<3.4.0@dev"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require-dev": {
		"phpstan/phpstan": "^2.2",
		"phpunit/phpunit": "^9.5",
		"phpunit/dbunit": "^4.0",
		"friendsoftwig/twigcs": "^5.1",
		"squizlabs/php_codesniffer": "^4.0"
	}
}
